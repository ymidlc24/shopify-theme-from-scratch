{% assign visible_count = 0 %}
{% for item in cart.items %}
  {% unless item.properties._hidden == "true" %}
    {% assign visible_count = visible_count | plus: item.quantity %}
  {% endunless %}
{% endfor %}

<style>
  input[type="number"]::-webkit-inner-spin-button,
  input[type="number"]::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  input[type="number"] {
    -moz-appearance: textfield;
  }
</style>

<script src="{{ 'cart-update.js' | asset_url }}" defer="defer"></script>

<div id="main-cart" class="container tw:mx-auto tw:px-[20px] tw:py-[40px] tw:min-h-[65vh]">
  {% if cart.item_count == 0 %}
    <div class="tw:text-center tw:py-[60px] tw:px-[20px]">
      <h1 class="tw:text-[32px] tw:font-semibold tw:text-[#333] tw:m-0">{{ 'cart.title' | t }}</h1>
      <p class="tw:text-[20px] tw:text-[#666] tw:mb-[30px] tw:mt-4">{{ 'cart.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="tw:inline-block tw:bg-[#b35b3a] tw:text-white tw:px-[40px] tw:py-[12px] tw:rounded-[50px] tw:text-[13px] tw:font-bold tw:uppercase tw:no-underline hover:tw:bg-[#964a2f]">
        Continue Shopping
      </a>
    </div>
  {% else %}
    
    <form action="{{ routes.cart_url }}" method="post" id="cart-form">
      <div class="tw:flex tw:justify-between tw:items-center tw:mb-[40px] tw:border-b-2 tw:border-[#f0f0f0] tw:pb-[20px]">
        <h1 class="tw:text-[32px] tw:font-semibold tw:text-[#333] tw:m-0">{{ 'cart.title' | t }}</h1>
        <p class="tw:text-[16px] tw:text-[#888] tw:m-0">{{ visible_count }} {{ visible_count | pluralize: 'item', 'items' }}</p>
      </div>

      <div class="tw:overflow-x-auto">
        <table class="tw:w-full tw:border-collapse tw:mb-[30px]">
          <thead class="tw:bg-[#f9f9f9] tw:border-b-2 tw:border-[#e0e0e0]">
            <tr>
              <th class="tw:text-left tw:p-[15px] tw:font-semibold tw:text-[#333] tw:text-[14px] tw:uppercase">Product</th>
              <th class="tw:text-left tw:p-[15px] tw:font-semibold tw:text-[#333] tw:text-[14px] tw:uppercase">Price</th>
              <th class="tw:text-left tw:p-[15px] tw:font-semibold tw:text-[#333] tw:text-[14px] tw:uppercase">Quantity</th>
              <th class="tw:text-left tw:p-[15px] tw:font-semibold tw:text-[#333] tw:text-[14px] tw:uppercase">Total</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {% for item in cart.items %}
              {% if item.properties._hidden == "true" %}{% continue %}{% endif %}
              
              {% assign bundle_unit_price = item.final_price %}
              {% assign bundle_line_price = item.final_line_price %}
              {% assign current_bundle_id = item.properties._bundleId | append: "" %}

              {% for addon in cart.items %}
                {% assign addon_parent = addon.properties._parentBundle | append: "" %}
                {% if addon.properties._hidden == "true" and addon_parent == current_bundle_id and current_bundle_id != "" %}
                  {% assign bundle_unit_price = bundle_unit_price | plus: addon.final_price %}
                  {% assign bundle_line_price = bundle_line_price | plus: addon.final_line_price %}
                {% endif %}
              {% endfor %}

              {% assign max_qty = item.variant.inventory_quantity %}
              {% if item.variant.inventory_policy == 'continue' or item.variant.inventory_management == null %}
                {% assign max_qty = 999 %}
              {% endif %}

              <tr class="tw:border-b tw:border-[#f0f0f0]" data-key="{{ item.key }}">
                <td class="tw:p-[15px] md:tw:p-[20px_15px]">
                  <div class="tw:flex tw:gap-[15px] tw:items-start">
                    {% if item.image %}
                      <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.image.alt | escape }}" class="tw:w-[60px] tw:h-[60px] md:tw:w-[80px] md:tw:h-[80px] tw:object-cover tw:rounded-[4px]" width="100" height="100">
                    {% endif %}
                    <div>
                      <h3 class="tw:m-[0_0_8px_0] tw:text-[16px] tw:font-bold">
                        <a href="{{ item.url }}" class="tw:text-inherit tw:no-underline hover:tw:underline">{{ item.product.title }}</a>
                      </h3>
                      {% if item.variant.title != 'Default Title' %}
                        <p class="tw:m-0 tw:text-[14px] tw:text-[#888]">{{ item.variant.title }}</p>
                      {% endif %}
                      {% if item.properties['Add-ons'] and item.properties['Add-ons'] != 'None' %}
                        <p class="tw:m-[4px_0_0_0] tw:text-[12px] tw:text-[#b35b3a] tw:font-semibold tw:italic">
                          + {{ item.properties['Add-ons'] }}
                        </p>
                      {% endif %}
                    </div>
                  </div>
                </td>
                <td class="tw:p-[15px]">{{ bundle_unit_price | money }}</td>
                <td class="tw:p-[15px]">
                  <div class="quantity-stepper tw:flex tw:items-center tw:border tw:border-[#ccc] tw:w-max tw:rounded-[4px] tw:overflow-hidden tw:bg-white">
                    <button type="button" class="minus tw:px-3 tw:py-1 tw:bg-gray-50 hover:tw:bg-gray-100">-</button>
                    <input 
                      type="number" 
                      name="updates[]" 
                      value="{{ item.quantity }}" 
                      min="0" 
                      max="{{ max_qty }}"
                      class="tw:w-[50px] tw:text-center tw:border-none tw:outline-none tw:py-1 tw:appearance-none no-arrows"
                    >
                    <button type="button" class="plus tw:px-3 tw:py-1 tw:bg-gray-50 hover:tw:bg-gray-100">+</button>
                  </div>
                </td>
                <td class="tw:p-[15px]">{{ bundle_line_price | money }}</td>
                <td class="tw:p-[15px]">
                  <a href="{{ item.url_to_remove }}" class="tw:text-[#d9534f] tw:text-[14px] tw:underline hover:tw:text-[#c9302c]">Remove</a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="tw:flex tw:flex-col tw:items-end tw:mt-10">
        <div class="tw:mb-[30px] tw:w-full md:tw:w-[350px]">
          <div class="tw:flex tw:justify-between tw:mb-[12px] tw:text-[14px] md:tw:text-[16px]">
            <span class="tw:text-[#666]">Subtotal:</span>
            <span class="tw:font-medium tw:text-[#333]">{{ cart.total_price | money }}</span>
          </div>
          <div class="tw:flex tw:justify-between tw:border-t-2 tw:border-[#e0e0e0] tw:pt-[12px] tw:text-[20px] tw:font-semibold">
            <span>Total:</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
        </div>

        <div class="tw:flex tw:flex-col md:tw:flex-row tw:gap-[15px] tw:w-full md:tw:w-auto">
          <a href="/collections/all" class="tw:inline-block tw:px-[30px] tw:py-[12px] tw:bg-white tw:text-[#333] tw:border-2 tw:border-[#ddd] tw:rounded-[50px] tw:text-[13px] tw:font-bold tw:uppercase tw:tracking-wider tw:text-center tw:no-underline hover:tw:bg-gray-50">
            {{ 'cart.continue_shopping' | t }}
          </a>
          {% assign base_styles = "tw:inline-block tw:px-[36px] tw:py-[14px] tw:text-white tw:font-bold tw:uppercase tw:tracking-[0.15em] tw:leading-none tw:cursor-pointer tw:text-center tw:no-underline tw:transition-all tw:duration-300 tw:hover:translate-y-[-1px] tw:focus:outline-none tw:bg-[#b35b3a] tw:border-[3px] tw:border-[#aa4d2a] tw:rounded-[50px] tw:hover:border-[#db8160]" %}
          <button type="submit" name="checkout" class="{{ base_styles }}">
            Checkout
          </button>
        </div>
      </div>
    </form>
  {% endif %}
</div>

{% schema %}
{
  "name": "Main Cart",
  "settings": []
}
{% endschema %}