<cart-notification id="cart-notification" class="tw:fixed tw:inset-0 tw:z-9999 tw:flex tw:items-center tw:justify-center tw:hidden">
  <div class="tw:absolute tw:inset-0 tw:bg-black/50 modal-close-trigger"></div>
  <div class="tw:relative tw:bg-white tw:rounded-lg tw:shadow-2xl tw:w-full tw:max-w-112.5 tw:mx-4 tw:overflow-hidden">
    <div class="tw:p-6">
      <div class="tw:flex tw:justify-between tw:items-center tw:mb-4">
        <h2 class="tw:text-lg tw:font-bold tw:text-gray-800">Added to cart</h2>
        <button type="button" class="modal-close-trigger tw:text-gray-400 hover:tw:text-gray-600 transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <div class="tw:flex tw:gap-4 tw:mb-6 tw:items-center">
        <div class="tw:w-24 tw:h-24 tw:bg-gray-50 tw:rounded tw:overflow-hidden tw:border tw:border-gray-100">
          {% # theme-check-disable-next-line RemoteAsset %}
          <img id="modal-product-image" src="" alt="" class="tw:w-full tw:h-full tw:object-cover" width="200px" height="200px">
        </div>
        <div class="tw:flex-1">
          <h3 id="modal-product-title" class="tw:font-bold tw:text-base tw:text-gray-900 tw:mb-1"></h3>
          <p class="tw:text-sm tw:text-gray-500">
            <span id="modal-product-price" class="tw:font-bold tw:text-[#b35b3a]"></span> | <span id="modal-product-qty"></span>
          </p>
        </div>
      </div>

      <div class="tw:flex tw:flex-col tw:gap-3">
        <form action="/checkout" method="post">
          <button type="submit" class="tw:w-full tw:bg-[#b35b3a] tw:text-white tw:py-3.5 tw:rounded-md tw:font-bold tw:uppercase tw:text-[11px] tw:tracking-widest hover:tw:bg-[#964a2f] transition-all">
            Checkout
          </button>
        </form>
        <a href="{{ routes.cart_url }}" class="tw:text-center tw:py-2 tw:text-xs tw:font-bold tw:uppercase tw:tracking-widest tw:text-gray-500 hover:tw:text-gray-800 tw:underline">
          View My Cart
        </a>
      </div>
    </div>
  </div>
</cart-notification>

{% schema %}
{
  "name": "Cart Notification",
  "settings": []
}
{% endschema %}