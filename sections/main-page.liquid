{% layout 'theme' %}

<div class="container">
  <main class="page-template page" style="min-height: 60vh;">
    <div class="page-wrapper">
      <header class="page-header">
        <h1 class="page-title">{{ page.title }}</h1>
      </header>

      <div class="page-content rte">
        {{ page.content }}
      </div>
    </div>
  </main>
</div>

{%  schema  %}
  {
    "name": "Main Page",
    "tag": "section",
    "settings": [],
    "presets": [
      {
        "name": "Main Page"
      }
    ]
  }
{% endschema %}
