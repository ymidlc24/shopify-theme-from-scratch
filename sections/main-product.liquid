<div class="container tw:mx-auto">
  <div class="tw:flex tw:gap-[40px] tw:my-[40px] tw:items-start tw:min-h-[55vh]">
    <div class="tw:shrink-0">
      <img 
        src="{{ product.featured_image | image_url: width: 400 }}" 
        alt="{{ product.title }}"
        class="tw:w-[400px] tw:h-[400px] tw:object-cover tw:rounded-[8px] tw:bg-[#f5f5f5]"
        width="400px"
        height="400px"
      >
    </div>

    <div class="tw:flex-1 tw:flex tw:flex-col">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'title' %}
            <h1 class="tw:text-[2rem] tw:font-bold tw:mb-[16px]">{{ product.title }}</h1>
          
          {% when 'description' %}
            <div class="tw:text-[#555] tw:text-[1rem]">
              {{ product.description }}
            </div>

          {% when 'metafield' %}
            {% if product.metafields.custom.ingredients %}
              <div class="tw:mt-0">
                <h3 class="tw:font-bold">{{ 'product.ingredients' | t }}</h3>
                <p class="tw:text-[#555] tw:text-[1rem]">{{ product.metafields.custom.ingredients }}</p>
              </div>
            {% endif %}

          {% when 'price' %}
            <p class="tw:text-[1.5rem] tw:text-[#2d2d2d] tw:mb-[24px]">{{ product.price | money }}</p>

          {% when 'add_to_cart' %}
            {% form 'product', product %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              
              {% unless product.has_only_default_variant %}
                <div class="tw:mb-[20px]">
                  {% for option in product.options_with_values %}
                    <div class="tw:mb-[10px]">
                      <label class="tw:block tw:font-bold">{{ option.name }}</label>
                      <select class="variant-select tw:p-[8px] tw:w-full tw:rounded-[4px] tw:border tw:border-[#ccc]" data-index="option{{ forloop.index }}">
                        {% for value in option.values %}
                          <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                            {{ value }}
                          </option>
                        {% endfor %}
                      </select>
                    </div>
                  {% endfor %}
                </div>
              {% endunless %}

              {% render 'btn-primary', 
                 text: 'Add to Cart', 
                 type: 'submit', 
                 class: 'tw:mt-[16px]' 
              %}
            {% endform %}
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Main Product",
    "tag": "section",
    "blocks": [
      {
        "type": "@app"
      },
      {
        "type": "title",
        "name": "Title"
      }, {
        "type": "description",
        "name": "Description"
      }, {
        "type": "metafield",
        "name": "Metafield"
      },  {
        "type": "price",
        "name": "Price"
      }, {
        "type": "add_to_cart",
        "name": "Add to Cart Button"
      }
    ],
    "presets": [
      {
        "name": "Main Product"
      }
    ]
  }
{% endschema %}