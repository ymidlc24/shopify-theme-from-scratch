<script id="CartInventoryJson-{{ section.id }}" type="application/json">
  {{ cart | json }}
</script>

<div
  class="container tw:mx-auto"
  id="ProductSection-{{ section.id }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  <div class="tw:flex tw:gap-10 tw:my-10 tw:items-start tw:min-h-[55vh]">
    <div class="tw:shrink-0">
      <img
        id="product-image-{{ section.id }}"
        src="{{ product.selected_or_first_available_variant.featured_image | default: product.featured_image | image_url: width: 400 }}"
        alt="{{ product.title | escape }}"
        class="tw:w-100 tw:h-100 tw:object-cover tw:rounded-2 tw:bg-[#f5f5f5]"
        width="400"
        height="400"
      >
    </div>

    <div class="tw:flex-1 tw:flex tw:flex-col">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'title' %}
            <h1 class="tw:text-[2rem] tw:font-bold tw:mb-4">{{ product.title }}</h1>
          {% when 'description' %}
            <div class="tw:text-[#555] tw:text-[1rem] tw:mb-5">{{ product.description }}</div>
          {% when 'metafield' %}
            {% if product.metafields.custom.ingredients %}
              <div class="tw:mt-0 tw:mb-5">
                <h3 class="tw:font-bold">{{ 'product.ingredients' | t }}</h3>
                <p class="tw:text-[#555] tw:text-[1rem]">{{ product.metafields.custom.ingredients }}</p>
              </div>
            {% endif %}
          {% when 'price' %}
            <p id="product-price-{{ section.id }}" class="tw:text-[1.5rem] tw:text-[#2d2d2d] tw:mb-6">{{ product.selected_or_first_available_variant.price | money }}</p>

          {% when 'inventory_status' %}
            <div id="inventory-status-{{ section.id }}" class="tw:mb-5 tw:hidden">
              <div class="tw:flex tw:justify-between tw:items-end tw:mb-2">
                <span id="stock-label-{{ section.id }}" class="tw:text-[12px] tw:font-bold tw:uppercase tw:tracking-widest"></span>
                <span id="stock-count-{{ section.id }}" class="tw:text-[11px] tw:text-gray-400"></span>
              </div>
              <div class="tw:w-full tw:h-1.5 tw:bg-gray-100 tw:rounded-full tw:overflow-hidden">
                <div
                  id="stock-bar-{{ section.id }}"
                  class="tw:h-full tw:transition-all tw:duration-500 tw:ease-out tw:bg-[#b35b3a]"
                  style="width: 0%"></div>
              </div>
            </div>

          {% when 'add_to_cart' %}
            {% assign initial_variant = product.selected_or_first_available_variant %}
            {% assign initial_cart_qty = 0 %}
            {% for item in cart.items %}
              {% if item.variant_id == initial_variant.id %}
                {% assign initial_cart_qty = item.quantity %}{% endif %}
            {% endfor %}

            <form action="{{ routes.cart_add_url }}" method="post" id="product-form">
              {% unless product.has_only_default_variant %}
                <div class="tw:mb-5">
                  {% for option in product.options_with_values %}
                    <div class="tw:mb-2.5">
                      <h3 class="tw:font-bold">{{ option.name }}</h3>
                      <select class="variant-select tw:p-2 tw:w-full tw:rounded-1 tw:border tw:border-[#ccc] tw:bg-white" data-index="option{{ forloop.index }}">
                        {% for value in option.values %}
                          <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                        {% endfor %}
                      </select>
                    </div>
                  {% endfor %}
                </div>
              {% endunless %}

              {% unless product.tags contains 'Food' %}
                {% assign espresso = all_products['espresso-shot'] %}
                {% assign oatmilk = all_products['oat-milk'] %}
                
                <script type="application/json" id="AddonMap-{{ section.id }}">
                  {
                    "Espresso Shot": {{ espresso.selected_or_first_available_variant.id | default: 0 | json }},
                    "Oat Milk": {{ oatmilk.selected_or_first_available_variant.id | default: 0 | json }}
                  }
                </script>

                <h3 class="tw:font-bold">Add-ons</h3>
                <div class="tw:grid tw:grid-cols-1 tw:gap-2 tw:mb-5">
                  {% if espresso %}
                    <label class="tw:cursor-pointer tw:block tw:mb-2">
                      <input type="checkbox" 
                            class="tw:sr-only tw:peer addon-checkbox" 
                            data-addon-name="Espresso Shot" 
                            data-addon-price="{{ espresso.price }}"> 
                      
                      <div class="addon-label tw:flex tw:justify-between tw:items-center tw:p-3 tw:border tw:rounded-md tw:transition-all 
                                  tw:bg-white tw:border-[#ccc] 
                                  tw:peer-checked:border-[#b35b3a] tw:peer-checked:bg-[#fdf8f6] 
                                  tw:peer-checked:border-2
                                  hover:tw:border-[#b35b3a]">
                        <span class="tw:text-[14px]">Extra Espresso Shot</span>
                        <span class="tw:text-[13px] tw:font-bold">+ {{ espresso.price | money }}</span>
                      </div>
                    </label>
                  {% endif %}

                  {% if oatmilk %}
                    <label class="tw:cursor-pointer tw:block">
                      <input type="checkbox" class="tw:sr-only tw:peer addon-checkbox" 
                            data-addon-name="Oat Milk" 
                            data-addon-price="{{ oatmilk.price }}">

                      <div class="addon-label tw:flex tw:justify-between tw:items-center tw:p-3 tw:border tw:rounded-md tw:transition-all 
                                  tw:bg-white tw:border-[#ccc]
                                  tw:peer-checked:border-[#b35b3a] 
                                  tw:peer-checked:bg-[#fdf8f6] 
                                  tw:peer-checked:border-2
                                  hover:tw:border-[#b35b3a]">
                        <span class="tw:text-[14px]">Substitute Oat Milk</span>
                        <span class="tw:text-[13px] tw:font-bold">+ {{ oatmilk.price | money }}</span>
                      </div>
                    </label>
                  {% endif %}
                </div>
              {% endunless %}

              <div class="tw:mb-5 tw:mt-5">
                <h3 class="tw:font-bold">Quantity</h3>
                <div class="tw:flex tw:items-center tw:border tw:border-[#ccc] tw:w-max tw:rounded-1 tw:overflow-hidden">
                  <button type="button" class="tw:px-4 tw:py-2 tw:bg-gray-50" onclick="let i=this.nextElementSibling; i.stepDown(); i.dispatchEvent(new Event('input', {bubbles:true}));">-</button>
                  <input 
                    type="number" 
                    name="quantity" 
                    value="{% if initial_cart_qty > 0 %}{{ initial_cart_qty }}{% else %}1{% endif %}" 
                    min="1" 
                    class="tw:w-15 tw:text-center tw:border-none tw:outline-none tw:py-2 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
                  >
                  <button type="button" class="tw:px-4 tw:py-2 tw:bg-gray-50" onclick="let i=this.previousElementSibling; i.stepUp(); i.dispatchEvent(new Event('input', {bubbles:true}));">+</button>
                </div>
              </div>

              {% assign base_styles = "tw:inline-block tw:px-9 tw:py-3.5 tw:text-white tw:font-bold tw:uppercase tw:tracking-[0.15em] tw:leading-none tw:cursor-pointer tw:text-center tw:no-underline tw:transition-all tw:duration-300 tw:hover:-translate-y-0.25 tw:focus:outline-none tw:bg-[#b35b3a] tw:border-[3px] tw:border-[#aa4d2a] tw:rounded-[50px] tw:hover:border-[#db8160]" %}
              <button 
                type="submit" 
                id="AddToCart-{{ section.id }}"
                data-variant-id="{{ initial_variant.id }}" 
                {% unless initial_variant.available %}disabled{% endunless %} 
                class="{{ base_styles }} {% unless initial_variant.available %}tw:opacity-50 tw:cursor-not-allowed{% endunless %}"
              >
                <span>
                  {% if initial_variant.available %}
                    Add to Cart
                  {% else %}
                    Out of Stock
                  {% endif %}
                </span>
              </button>
            </form>

            <script type="application/json" id="VariantJson-{{ section.id }}">
              [{% for variant in product.variants %}{"id": {{ variant.id }}, "options": {{ variant.options | json }}, "price": {{ variant.price }}, "available": {{ variant.available }}, "inventory_management": {{ variant.inventory_management | json }}, "inventory_policy": {{ variant.inventory_policy | json }}, "inventory_quantity": {{ variant.inventory_quantity | default: 0 }}, "featured_image": {% if variant.featured_image %}{"src": {{ variant.featured_image.src | json }}}{% else %}null{% endif %}}{% unless forloop.last %},{% endunless %}{% endfor %}]
            </script>

            <script type="application/json" id="CartInventoryJson-{{ section.id }}">
              {"items": [{% for item in cart.items %}{"variant_id": {{ item.variant_id }}, "quantity": {{ item.quantity }}}{% unless forloop.last %},{% endunless %}{% endfor %}]}
            </script>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Main Product",
    "blocks": [
      {
        "type": "title",
        "name": "Title"
      },
      {
        "type": "description",
        "name": "Description"
      },
      {
        "type": "metafield",
        "name": "Metafield"
      },
      {
        "type": "price",
        "name": "Price"
      },
      {
        "type": "inventory_status",
        "name": "Inventory Checker"
      },
      {
        "type": "add_to_cart",
        "name": "Add to Cart Button"
      }
    ]
  }
{% endschema %}