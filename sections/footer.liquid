<footer class="tw:bg-[#4e2b1c] tw:text-[#fff] tw:py-[48px]">
  <div class="container tw:mx-auto tw:flex tw:flex-wrap tw:gap-[40px]">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'menu' %}
          <div class="tw:flex-1 tw:min-w-[200px]">
            <h2 class="tw:text-[1.2rem] tw:mb-[16px] tw:tracking-[1px] tw:uppercase tw:font-bold">
              {{ block.settings.menu_title }}
            </h2>

            <ul class="tw:list-none tw:p-0 tw:m-0">
              {% for link in linklists[block.settings.menu_links].links %}
                <li class="tw:mb-[10px]">
                  <a href="{{ link.url }}" class="tw:text-[#fff] tw:no-underline tw:transition-colors tw:duration-[0.2s] tw:hover:text-[#ffb347]">
                    {{ link.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>

        {% when 'newsletter' %}
          <div class="tw:flex-1 tw:min-w-[300px] tw:max-w-full md:tw:max-w-[450px]">
            <h2 class="tw:text-[1.2rem] tw:mb-[16px] tw:tracking-[1px] tw:uppercase tw:font-bold">Newsletter</h2>
            <p class="tw:mb-2">Sign up to get the latest updates and offers.</p>
           
            {% form 'contact', class: 'tw:flex tw:items-stretch tw:mt-[8px]' %}
              <input type="hidden" name="form_type" value="customer">
              <input type="hidden" name="utf8" value="✓">
              
              <input
                type="email"
                name="contact[email]"
                placeholder="Your email address"
                class="tw:flex-1 tw:p-[10px] tw:border tw:border-[#ddd] tw:rounded-l-[4px] tw:text-[1rem] tw:text-black tw:bg-white tw:outline-none tw:min-w-0"
                required
              >
              
              <button 
                type="submit" 
                class="tw:bg-[#b35b3a] tw:text-white tw:px-[24px] tw:border tw:border-[#aa4d2a] tw:border-l-0 tw:rounded-r-[4px] tw:text-[13px] tw:font-bold tw:uppercase tw:tracking-widest tw:transition-all tw:hover:bg-[#db8160] tw:whitespace-nowrap"
              >
                Subscribe
              </button>
            {% endform %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</footer>

{% schema %}
  {
    "name": "Footer",
    "tag": "section",
    "blocks": [
      {
        "type": "menu",
        "name": "Footer Menu",
        "settings": [
          {
            "type": "text",
            "id": "menu_title",
            "label": "Menu Title",
            "default": "Quick Links"
          }, {
            "type": "link_list",
            "id": "menu_links",
            "label": "Menu Links"
          }
        ]
      }, {
        "type": "newsletter",
        "name": "Newsletter Signup",
        "settings": []
      }
    ]
  }
{% endschema %}