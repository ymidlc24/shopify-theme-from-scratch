{% assign visible_count = 0 %}
{% for item in cart.items %}
  {% unless item.properties._hidden %}
    {% assign visible_count = visible_count | plus: item.quantity %}
  {% endunless %}
{% endfor %}

<div class="container tw:mx-auto tw:px-[20px] tw:py-[40px] tw:min-h-[65vh]">
  {% if cart.item_count == 0 %}
    <div class="tw:text-center tw:py-[60px] tw:px-[20px]">
      <h1 class="tw:text-[32px] tw:font-semibold tw:text-[#333] tw:m-0">{{ 'cart.title' | t }}</h1>
      <p class="tw:text-[20px] tw:text-[#666] tw:mb-[30px] tw:mt-4">{{ 'cart.empty' | t }}</p>
      {% render 'btn-primary', text: 'Continue Shopping', url: routes.all_products_collection_url %}
    </div>
  {% else %}
    <div class="tw:flex tw:justify-between tw:items-center tw:mb-[40px] tw:border-b-2 tw:border-[#f0f0f0] tw:pb-[20px]">
      <h1 class="tw:text-[32px] tw:font-semibold tw:text-[#333] tw:m-0">{{ 'cart.title' | t }}</h1>
      <p class="tw:text-[16px] tw:text-[#888] tw:m-0">{{ visible_count }} {{ visible_count | pluralize: 'item', 'items' }}</p>
    </div>

    <div class="tw:overflow-x-auto">
      <table class="tw:w-full tw:border-collapse tw:mb-[30px]">
        <thead class="tw:bg-[#f9f9f9] tw:border-b-2 tw:border-[#e0e0e0]">
          <tr>
            <th class="tw:text-left tw:p-[15px] tw:font-semibold tw:text-[#333] tw:text-[14px] tw:uppercase">Product</th>
            <th class="tw:text-left tw:p-[15px] tw:font-semibold tw:text-[#333] tw:text-[14px] tw:uppercase">Price</th>
            <th class="tw:text-left tw:p-[15px] tw:font-semibold tw:text-[#333] tw:text-[14px] tw:uppercase">Quantity</th>
            <th class="tw:text-left tw:p-[15px] tw:font-semibold tw:text-[#333] tw:text-[14px] tw:uppercase">Total</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
            {% if item.properties._hidden %}{% continue %}{% endif %}
            <tr class="tw:border-b tw:border-[#f0f0f0]">
              <td class="tw:p-[15px] md:tw:p-[20px_15px]">
                <div class="tw:flex tw:gap-[15px] tw:items-start">
                  {% if item.image %}
                    <img
                      src="{{ item.image | image_url: width: 100 }}"
                      alt="{{ item.image.alt }}"
                      class="tw:w-[60px] tw:h-[60px] md:tw:w-[80px] md:tw:h-[80px] tw:object-cover tw:rounded-[4px]"
                      width="100px"
                      height="auto"
                    >
                  {% endif %}
                  <div>
                    <h3 class="tw:m-[0_0_8px_0] tw:text-[16px] tw:font-bold">
                      <a href="{{ item.url }}" class="tw:text-inherit tw:no-underline hover:tw:underline">{{ item.title }}</a>
                    </h3>
                    {% if item.variant.title != 'Default Title' %}
                      <p class="tw:m-0 tw:text-[14px] tw:text-[#888]">{{ item.variant.title }}</p>
                    {% endif %}
                  </div>
                </div>
              </td>
              <td class="tw:p-[15px]">{{ item.original_price | money }}</td>
              <td class="tw:p-[15px]">{{ item.quantity }}</td>
              <td class="tw:p-[15px]">{{ item.final_line_price | money }}</td>
              <td class="tw:p-[15px]">
                <a href="/cart/change?id={{ item.key }}&quantity=0" class="tw:text-[#d9534f] tw:text-[14px] tw:underline hover:tw:text-[#c9302c]">Remove</a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="tw:flex tw:flex-col tw:items-end tw:mt-10">
      <div class="tw:mb-[30px] tw:w-[300px]">
        <div class="tw:flex tw:justify-between tw:mb-[12px] tw:text-[14px] md:tw:text-[16px]">
          <span class="tw:text-[#666]">Subtotal:</span>
          <span class="tw:font-medium tw:text-[#333]">{{ cart.items_subtotal_price | money }}</span>
        </div>
        <div class="tw:flex tw:justify-between tw:mb-[12px] tw:text-[14px] md:tw:text-[16px]">
          <span class="tw:text-[#666]">Shipping:</span>
          <span class="tw:font-medium tw:text-[#333]">Calculated at checkout</span>
        </div>
        <div class="tw:flex tw:justify-between tw:mb-[12px] tw:text-[14px] md:tw:text-[16px]">
          <span class="tw:text-[#666]">Tax:</span>
          <span class="tw:font-medium tw:text-[#333]">Calculated at checkout</span>
        </div>
        <div class="tw:flex tw:justify-between tw:border-t-2 tw:border-[#e0e0e0] tw:pt-[12px] tw:text-[20px] tw:font-semibold">
          <span>Total:</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
      </div>

      <div class="tw:flex tw:flex-row md:tw:flex-row tw:gap-[15px] tw:w-[300px]">
        <a href="/collections/all" class="tw:inline-block tw:px-[36px] tw:py-[14px] tw:bg-[#f5f5f5] tw:text-[#333] tw:border-[3px] tw:border-[#ddd] tw:rounded-[50px] tw:text-[13px] tw:font-bold tw:uppercase tw:tracking-[0.15em] tw:text-center tw:no-underline tw:transition-all hover:tw:bg-[#e8e8e8] hover:tw:border-[#bbb]">
          {{ 'cart.continue_shopping' | t }}
        </a>
        
        {% render 'btn-primary', 
           text: 'Checkout', 
           type: 'button',
        %}
      </div>
    </div>
  {% endif %}
</div>